{
  "name": "pump-it",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check",
    "dev": "vite dev --port 3000 --host",
