    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/router-plugin": "^1.168.18",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "es-toolkit": "^1.47.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "neverthrow": "^8.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-lite-youtube-embed": "^3.6.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.1",
